MONITORING_PG_HOST=postgres
MONITORING_PG_PORT=5432
MONITORING_PG_DB=monitoring
MONITORING_PG_USER=monitoring
MONITORING_PG_PASSWORD=monitoring
MONITORING_PSQL_BIN=psql

MONITORING_API_HOST=0.0.0.0
MONITORING_API_PORT=18070

MONITORING_INGESTOR_HOST=0.0.0.0
MONITORING_INGESTOR_PORT=18071
MONITORING_INGESTOR_POLL_INTERVAL_SEC=30
MONITORING_HELPER_TIMEOUT_SEC=5
MONITORING_COMMAND_DISPATCH_ENABLED=false
MONITORING_COMMAND_DISPATCH_BATCH_SIZE=20
MONITORING_COMMAND_DISPATCH_TIMEOUT_SEC=5
MONITORING_COMMAND_RETRY_MAX_ATTEMPTS=5
MONITORING_COMMAND_RETRY_BACKOFF_BASE_SEC=2
MONITORING_COMMAND_RETRY_BACKOFF_MAX_SEC=60

MONITORING_NODE_SOURCES_FILE=/app/config/nodes.json
MONITORING_DISCOVERY_URLS=http://host.docker.internal:18110/v1/edges,http://host.docker.internal:18110/v1/uplinks
MONITORING_DISCOVERY_API_TOKEN=change_me
MONITORING_DISCOVERY_TOKEN_HEADER=X-API-Token
# Optional per-URL tokens (same order as MONITORING_DISCOVERY_URLS).
# Example for shadow read API:
# MONITORING_DISCOVERY_URLS=http://host.docker.internal:18110/v1/edges,http://host.docker.internal:18110/v1/uplinks,http://host.docker.internal:18190/v1/edges,http://host.docker.internal:18190/v1/uplinks
# MONITORING_DISCOVERY_URL_TOKENS=change_me,change_me,shadow-read-smoke-token,shadow-read-smoke-token
MONITORING_CONTROL_PEERS_INGEST_ENABLED=true
MONITORING_CONTROL_PEERS_URL=http://host.docker.internal:18110/v1/peers
# Optional multi-source peers ingestion.
# MONITORING_CONTROL_PEERS_URLS=http://host.docker.internal:18110/v1/peers,http://host.docker.internal:18190/v1/peers
# MONITORING_CONTROL_PEERS_TOKENS=change_me,shadow-read-smoke-token
MONITORING_GATEWAY_FLAP_SWITCH_THRESHOLD=3
MONITORING_GATEWAY_FLAP_KEEP_THRESHOLD=1
MONITORING_LINK_FLAP_RECONNECTS_THRESHOLD=3
MONITORING_LINK_FLAP_HANDSHAKE_FAILURES_THRESHOLD=3
MONITORING_CONTROL_PEER_STARTING_MAX_AGE_SEC=14400
MONITORING_AUTO_RESOLVE_LINK_ALERTS_AFTER_SEC=900
MONITORING_ALERTS_ENABLED=true
MONITORING_ALERT_MIN_SEVERITY=warning
MONITORING_ALERTS_BATCH_SIZE=100
MONITORING_ALERT_TIMEOUT_SEC=5
MONITORING_ALERT_MAX_AGE_SEC=604800
# Telegram via webhook or direct Bot API (token + chat_id)
MONITORING_ALERT_TG_WEBHOOK_URL=
MONITORING_ALERT_TG_BOT_TOKEN=
MONITORING_ALERT_TG_CHAT_ID=
# MAX webhook endpoint
MONITORING_ALERT_MAX_WEBHOOK_URL=
# MAX direct API (preferred)
MONITORING_ALERT_MAX_BASE_URL=https://platform-api.max.ru
MONITORING_ALERT_MAX_TOKEN=
MONITORING_ALERT_MAX_CHAT_ID=
