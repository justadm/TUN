TUN_HELPER_SOCKET=/run/tun/runtime-helper.sock
TUN_HELPER_AUTH_TOKEN_FILE=/etc/tun/runtime-helper.token
TUN_HELPER_BOOTSTRAP_FILE=/etc/tun/bootstrap.json
TUN_HELPER_LEASE_OWNER=desktop-bridge
TUN_HELPER_LEASE_TTL=60s
TUN_HELPER_TIMEOUT=10s
TUN_HELPER_AUTOPILOT_MAX_STEPS=3
TUN_HELPER_AUTOPILOT_ALLOW_RESTART=true
TUN_HELPER_AUTOPILOT_INTERVAL=20s
TUN_HELPER_AUTOPILOT_DURATION=0s
TUN_HELPER_AUTOPILOT_CONTINUE_ON_ERROR=true
TUN_HELPER_BRIDGE_WAIT=true
TUN_HELPER_WAIT_STATE=established
TUN_HELPER_WAIT_TIMEOUT=20s
