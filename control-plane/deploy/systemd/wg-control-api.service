# /etc/systemd/system/wg-control-api.service
[Unit]
Description=WG Control API service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/wireguard/wg-portal.env
ExecStart=/usr/bin/python3 /usr/local/bin/wg_control_api_server.py
Restart=always
RestartSec=2
User=root
Group=root

[Install]
WantedBy=multi-user.target

