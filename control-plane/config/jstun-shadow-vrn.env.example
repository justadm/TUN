# JsTun shadow runtime on VRN

JSTUN_SHADOW_HOST=bridge-vrn

# Disposable Postgres
JSTUN_SHADOW_PGHOST=127.0.0.1
JSTUN_SHADOW_PGPORT=15432
JSTUN_SHADOW_PGDATABASE=jstun_shadow
JSTUN_SHADOW_PGUSER=jstun_shadow
JSTUN_SHADOW_PGPASSWORD=change-me

# Shadow service ports
JSTUN_SHADOW_CONTROL_API_HOST=127.0.0.1
JSTUN_SHADOW_CONTROL_API_PORT=18190
JSTUN_SHADOW_PORTAL_HTTP_HOST=127.0.0.1
JSTUN_SHADOW_PORTAL_HTTP_PORT=18210

# Shadow runtime paths
JSTUN_SHADOW_ROOT=/opt/jstun-shadow
JSTUN_SHADOW_ETC=/etc/jstun-shadow
JSTUN_SHADOW_VAR=/var/lib/jstun-shadow
JSTUN_SHADOW_PGDATA=/var/lib/jstun-shadow/postgres
JSTUN_SHADOW_RUNTIME=/var/lib/jstun-shadow/runtime
WG_PORTAL_IFACE=wgshadow0
WG_PORTAL_CONF=/var/lib/jstun-shadow/runtime/wgshadow0.conf
WG_PORTAL_ENV=/etc/jstun-shadow/jstun-shadow.env
WG_PORTAL_WG_BIN=/opt/jstun-shadow/bin/wgstub.py
WG_STUB_STATE=/var/lib/jstun-shadow/runtime/wgstub-state.json
WG_PORTAL_NET=10.250.0.0/24
WG_PORTAL_IP_START=50
WG_PORTAL_IP_END=250

# Optional DB-backed reads in control API
JSTUN_DB_READ_ENABLED=1
JSTUN_DB_READ_PEERS_ENABLED=1
JSTUN_DB_READ_UPLINKS_ENABLED=1
JSTUN_DB_READ_EVENTS_ENABLED=1
JSTUN_DB_WRITE_MIRROR_ENABLED=0
JSTUN_DB_WRITE_MIRROR_EVENTS_ENABLED=1
JSTUN_DB_PSQL_BIN=psql
JSTUN_DB_HOST=127.0.0.1
JSTUN_DB_PORT=15432
JSTUN_DB_NAME=jstun_shadow
JSTUN_DB_USER=jstun_shadow
JSTUN_DB_PASSWORD=change-me
