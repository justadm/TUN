# Core WireGuard access settings
WG_ENDPOINT=85.239.44.100:51820
WG_DNS=1.1.1.1, 8.8.8.8
WG_PORTAL_TTL_SEC=3600
WG_PORTAL_IP_START=50
WG_PORTAL_IP_END=250
WG_PORTAL_NET=10.8.0.0/24

# Portal and control API auth
WG_PORTAL_ADMIN_TOKEN=change-me
WG_CONTROL_API_TOKEN=change-me

# Portal -> control API
WG_PORTAL_USE_CONTROL_API=1
WG_CONTROL_API_BASE=http://127.0.0.1:18110/v1
WG_CONTROL_API_TIMEOUT_SEC=5
WG_CONTROL_API_FALLBACK_CLI=0

# Controlled read cutover for admin surfaces
JSTUN_ADMIN_READ_CANARY_ENABLED=0
JSTUN_ADMIN_READ_MODE_DEFAULT=local
JSTUN_READ_SHADOW_ENABLED=0
JSTUN_READ_SHADOW_BASE=http://127.0.0.1:18191/v1
JSTUN_READ_SHADOW_TOKEN=change-me
JSTUN_READ_SHADOW_TIMEOUT_SEC=5
JSTUN_READ_SHADOW_RESOURCES=peers,uplinks,peer_uplink,events

# Billing integration
TBANK_API_BASE=https://business.tbank.ru/openapi
TBANK_BEARER_TOKEN=change-me
TBANK_USE_STUB=0
WG_BILLING_FALLBACK_URL=https://www.tinkoff.ru/rm/r_QbvegWGXPM.bSevcVNkfN/wM7Ce36559

# Portal anti-abuse
WG_PORTAL_NEW_IP_MAX=1
WG_PORTAL_NEW_IP_EXEMPT_IPS=147.45.238.121

# Telegram alerts
WG_PORTAL_TG_BOT_TOKEN=change-me
WG_PORTAL_TG_CHAT_ID=13903713

# Geo/IP cache
WG_PORTAL_IP_GEO_CACHE_TTL_SEC=604800

# Optional DB-backed reads in control API
JSTUN_DB_READ_ENABLED=0
JSTUN_DB_READ_PEERS_ENABLED=1
JSTUN_DB_READ_UPLINKS_ENABLED=1
JSTUN_DB_READ_EVENTS_ENABLED=1
JSTUN_DB_WRITE_MIRROR_ENABLED=0
JSTUN_DB_WRITE_MIRROR_EVENTS_ENABLED=1
JSTUN_DB_PSQL_BIN=psql
JSTUN_DB_HOST=127.0.0.1
JSTUN_DB_PORT=15432
JSTUN_DB_NAME=jstun_shadow
JSTUN_DB_USER=jstun_shadow
JSTUN_DB_PASSWORD=change-me
JSTUN_WRITE_SHADOW_DB_TUNNEL_TARGET_HOST=user@91.221.109.60
JSTUN_WRITE_SHADOW_DB_TUNNEL_SSH_PORT=65022
JSTUN_WRITE_SHADOW_DB_TUNNEL_TARGET_PORT=15432
JSTUN_WRITE_SHADOW_DB_TUNNEL_LOCAL_PORT=15433
JSTUN_WRITE_SHADOW_DB_TUNNEL_IDENTITY_FILE=/home/opsadmin/.ssh/jstun_shadow_read_ed25519

# Optional live bridge-vrn edge adapter for real create/remove on VRN
JSTUN_VRN_EDGE_SSH_HOST=user@91.221.109.60
JSTUN_VRN_EDGE_SSH_PORT=65022
JSTUN_VRN_EDGE_IDENTITY_FILE=/home/opsadmin/.ssh/jstun_shadow_read_ed25519
JSTUN_VRN_EDGE_ENV=/etc/wireguard/wg-portal-vrn.env
JSTUN_VRN_EDGE_PYTHON=python3
JSTUN_VRN_EDGE_CLI=/usr/local/bin/wg_portal_vrn.py
JSTUN_VRN_EDGE_ENDPOINT=91.221.109.60:51820
JSTUN_VRN_EDGE_SERVER_PUB_PATH=/etc/wireguard/vrn_server.pub
JSTUN_VRN_EDGE_ROUTE_BIN=/usr/local/sbin/vrn-peer-route
